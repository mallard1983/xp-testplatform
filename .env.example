# XP Framework Test Platform — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored. Never commit it.
#
# Model API keys and search credentials are managed separately via the UI
# and stored in data/setup/keys.json (also gitignored).
# This file covers infrastructure configuration only.

# Neo4j credentials
# Must match the format: username/password
NEO4J_AUTH=neo4j/changeme

# Port the UI is served on (host machine)
UI_PORT=3000

# Per-request timeout for model calls, in seconds.
# Default is 7200 (2 hours). Large local models with extended thinking can
# take 10+ minutes per turn at depth — lower this only if you're on a fast API.
# LLM_TIMEOUT_SECONDS=7200
